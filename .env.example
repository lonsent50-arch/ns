# ============================================================
# Novel Studio — 云端部署环境变量清单
# 复制此文件为 .env（本地开发）或在 Railway/Render 后台逐项填入
# ============================================================

# ─── 必填：AI 模型 API Key ─────────────────────────────────
# DeepSeek API Key（https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Claude API Key（https://console.anthropic.com 获取，可选）
CLAUDE_API_KEY=

# Gemini API Key（https://aistudio.google.com 获取，可选）
GEMINI_API_KEY=

# ─── 必填：Supabase 数据库 ──────────────────────────────────
# 从 Supabase Dashboard > Settings > API 获取
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── CORS 跨域白名单（可选）─────────────────────────────────
# 多个域名用英文逗号分隔
# 不设置则默认允许 localhost 和 Vercel 常见域名
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ─── 安全配置 ───────────────────────────────────────────────
# 许可证密钥种子（生产环境务必替换为随机字符串）
LICENSE_SECRET=change-me-to-a-random-string

# 管理后台密码 SHA-256 hash
# 生成: python3 -c "import hashlib; print(hashlib.sha256('your-password'.encode()).hexdigest())"
ADMIN_PASSWORD_HASH=

# 管理后台令牌（用于 X-Admin-Token 鉴权，可选）
ADMIN_TOKEN=

# ─── 服务端口（Railway/Render 会自动设置 PORT，无需手动改）─
# PORT=5050
